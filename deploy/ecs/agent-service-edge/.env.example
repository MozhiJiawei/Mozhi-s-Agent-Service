# Copy this file to .env on the ECS host and fill in real values.

# HTTP remains useful for /health and short-lived public-IP validation.
CADDY_HTTP_SITE_ADDRESS=:80

# For public-IP HTTPS validation, use https://<public-ip> with
# CADDY_TLS_MODE=internal and curl -k because browsers and curl will not trust
# the internal certificate.
# For real domain HTTPS, set this to the domain and set CADDY_TLS_MODE=auto.
CADDY_HTTPS_SITE_ADDRESS=https://39.105.78.135
CADDY_TLS_MODE=internal

# Replace with a strong random token. The desktop frpc config must use the same value.
FRP_TOKEN=replace-with-strong-random-token

FRP_BIND_PORT=7000
HEALTH_PROXY_PORT=18081

# Defaults to HEALTH_PROXY_PORT for compatibility. Set explicitly once the real
# desktop API replaces the mock health service.
DESKTOP_API_PROXY_PORT=18081

# Caddy request_body max_size for /api/*.
API_MAX_BODY_SIZE=1MB

# Keep false for real callers. Set true only for temporary public-IP HTTP
# validation before domain HTTPS is available. HTTP callers must also send
# X-Mozhi-Allow-Http-Api: true so accidental cleartext API calls still fail.
ALLOW_HTTP_API=false
