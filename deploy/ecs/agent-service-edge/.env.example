# Copy this file to .env on the ECS host and fill in real values.

# Use :80 for temporary public-IP HTTP validation before ICP/domain HTTPS is ready.
# Use haohaoxiaoyu.top after DNS and ICP/domain access are ready.
CADDY_SITE_ADDRESS=:80

# Replace with a strong random token. The desktop frpc config must use the same value.
FRP_TOKEN=replace-with-strong-random-token

FRP_BIND_PORT=7000
HEALTH_PROXY_PORT=18081

